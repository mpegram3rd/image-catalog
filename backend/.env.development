# Development Environment Configuration
ENVIRONMENT=development

# LLM Configuration
LLM_MODEL=gpt-4o-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_PROVIDER=openai
LLM_URL=https://api.openai.com/v1
LLM_API_KEY=your-openai-api-key-here
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3

# Hugging Face
HF_TOKEN=your-huggingface-token-here

# File Paths
PHOTOS_BASE_PATH=./photos
PHOTOS_URL_BASE=http://localhost:8000/photos
DB_BASE_PATH=./data

# Image Processing
THUMBNAIL_WIDTH=200
THUMBNAIL_HEIGHT=200
MAX_IMAGE_SIZE=10485760  # 10MB
SUPPORTED_FORMATS=[".jpg", ".jpeg", ".png"]

# Database
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_PREFIX=image_catalog_dev

# Logging (Development - more verbose)
LOG_LEVEL=DEBUG
LOG_FILE=./logs/development.log
LOG_JSON_FORMAT=false
LOG_MAX_SIZE=104857600  # 100MB
LOG_BACKUP_COUNT=3

# Server (Development)
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
SERVER_WORKERS=1
DEBUG=true
RELOAD=true

# CORS (Development - permissive)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080", "http://127.0.0.1:3000"]
CORS_CREDENTIALS=true

# Search
DEFAULT_SEARCH_THRESHOLD=medium
MAX_SEARCH_RESULTS=50

# Performance
MAX_CONCURRENT_INDEXING=2
MAX_CONCURRENT_SEARCHES=5