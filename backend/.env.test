# Test Environment Configuration
ENVIRONMENT=test

# LLM Configuration (Test - using faster/cheaper models)
LLM_MODEL=gpt-3.5-turbo
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_PROVIDER=openai
LLM_URL=https://api.openai.com/v1
LLM_API_KEY=test-api-key
LLM_TIMEOUT=10
LLM_MAX_RETRIES=1

# Hugging Face
HF_TOKEN=test-token

# File Paths (Test)
PHOTOS_BASE_PATH=./tests/fixtures/photos
PHOTOS_URL_BASE=http://localhost:8001/photos
DB_BASE_PATH=./tests/data

# Image Processing (Test - smaller sizes)
THUMBNAIL_WIDTH=100
THUMBNAIL_HEIGHT=100
MAX_IMAGE_SIZE=1048576  # 1MB
SUPPORTED_FORMATS=[".jpg", ".png"]

# Database (Test)
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_PREFIX=image_catalog_test

# Logging (Test - minimal logging)
LOG_LEVEL=WARNING
LOG_FILE=./tests/logs/test.log
LOG_JSON_FORMAT=true
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=1

# Server (Test)
SERVER_HOST=127.0.0.1
SERVER_PORT=8001
SERVER_WORKERS=1
DEBUG=false
RELOAD=false

# CORS (Test - restrictive)
CORS_ORIGINS=["http://localhost:8001"]
CORS_CREDENTIALS=false

# Search (Test - smaller limits)
DEFAULT_SEARCH_THRESHOLD=small
MAX_SEARCH_RESULTS=10

# Performance (Test - reduced concurrency)
MAX_CONCURRENT_INDEXING=1
MAX_CONCURRENT_SEARCHES=2