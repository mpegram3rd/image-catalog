# Production Environment Configuration
ENVIRONMENT=production

# LLM Configuration (Production)
LLM_MODEL=gpt-4o
LLM_EMBEDDING_MODEL=text-embedding-3-large
LLM_PROVIDER=openai
LLM_URL=https://api.openai.com/v1
LLM_API_KEY=${OPENAI_API_KEY}
LLM_TIMEOUT=60
LLM_MAX_RETRIES=5

# Hugging Face
HF_TOKEN=${HUGGINGFACE_TOKEN}

# File Paths (Production)
PHOTOS_BASE_PATH=/app/data/photos
PHOTOS_URL_BASE=${PHOTOS_URL_BASE}
DB_BASE_PATH=/app/data/db

# Image Processing (Production)
THUMBNAIL_WIDTH=300
THUMBNAIL_HEIGHT=300
MAX_IMAGE_SIZE=20971520  # 20MB
SUPPORTED_FORMATS=[".jpg", ".jpeg", ".png", ".webp"]

# Database (Production)
CHROMA_HOST=${CHROMA_HOST:-chromadb}
CHROMA_PORT=${CHROMA_PORT:-8000}
CHROMA_COLLECTION_PREFIX=image_catalog_prod

# Logging (Production - structured logging)
LOG_LEVEL=INFO
LOG_FILE=/app/logs/application.log
LOG_JSON_FORMAT=true
LOG_MAX_SIZE=524288000  # 500MB
LOG_BACKUP_COUNT=10

# Server (Production)
SERVER_HOST=0.0.0.0
SERVER_PORT=${PORT:-8000}
SERVER_WORKERS=${SERVER_WORKERS:-4}
DEBUG=false
RELOAD=false

# CORS (Production - specific origins)
CORS_ORIGINS=${CORS_ORIGINS:-["https://yourdomain.com"]}
CORS_CREDENTIALS=true

# Search (Production)
DEFAULT_SEARCH_THRESHOLD=medium
MAX_SEARCH_RESULTS=100

# Performance (Production - higher concurrency)
MAX_CONCURRENT_INDEXING=8
MAX_CONCURRENT_SEARCHES=20
